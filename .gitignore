## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
.nuget/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# ASP.NET Core
appsettings.Development.json
secrets.json

# Publish output
publish/
wwwroot/dist/

# Entity Framework
*.mdf
*.ldf

# Azure Functions
local.settings.json

# Docker
docker-compose.override.yml

# Node modules (if frontend exists)
node_modules/

# Coverage reports
coverage/
*.coverage
*.coveragexml

# OS files
.DS_Store
Thumbs.db

# JetBrains Rider
_ReSharper*/
*.DotSettings.user

# Generated files
Generated/
*.generated.cs

# Temporary files
*.tmp
*.temp

# SQLite
*.db
*.sqlite

# Backup files
*.bak

# Logs
*.log